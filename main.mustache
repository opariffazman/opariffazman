{{#isHtml}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {{#seo}}<title>{{title}}</title>{{/seo}}
  {{#seo}}<meta name="description" content="{{description}}">{{/seo}}
  {{#seo}}<meta property="og:title" content="{{title}}">{{/seo}}
  {{#seo}}<meta property="og:description" content="{{description}}">{{/seo}}
  {{#seo}}<meta property="og:image" content="{{image}}">{{/seo}}
  {{#seo}}<meta property="og:url" content="{{{url}}}">{{/seo}}
  <meta property="og:type" content="profile">
  <meta name="twitter:card" content="summary">
  {{#seo}}<link rel="canonical" href="{{{url}}}">{{/seo}}
  <link rel="icon" type="image/png" href="opariffazman.png">
  <link rel="apple-touch-icon" href="images/apple-touch-icon.png">
  <style>
    body { background: #000; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; text-align: center; margin: 0; padding: 20px; }
    img { max-width: 100%; height: auto; }
    a { text-decoration: none; }
    hr { border: none; border-top: 1px solid #333; margin: 30px auto; max-width: 600px; }
  </style>
</head>
<body>
{{/isHtml}}

<div align="center">

<a href="https://git.io/typing-svg"><img src="{{{typingSvgUrl}}}" alt="Typing SVG" /></a>

<h1>{{name}}</h1>

<p>
    {{{professionalHtml}}}
</p>

<br>

<p>
    {{{badgeHtml}}}
</p>

<br>

{{{projectHtml}}}

<br>

<img src="{{{activityGraphUrl}}}" alt="GitHub Activity Graph" />

<br>

<p>
    {{{socialHtml}}}
</p>

<br>

<img src="{{{viewCounterUrl}}}" alt="Profile Views" />

</div>

{{#isHtml}}
</body>
</html>
{{/isHtml}}
